# FounderOS time management knowledge base.
TIME_MASTER_KB_DIR=/Users/nge/MAC BOOK的WPS云盘/林恩光的知识库/01_FounderOS_林总个人OS/08_时间管理大师
TIME_MASTER_DATA_DIR=
TIME_MASTER_DB_PATH=
TIME_MASTER_BACKUP_DIR=
TIME_MASTER_MARKDOWN_DIR=
TIME_MASTER_TIMEZONE=Asia/Shanghai
TIME_MASTER_USER_ID=
TIME_MASTER_PLAN_TIME=08:30
TIME_MASTER_FIRST_TASK_TIME=10:00
TIME_MASTER_MIDDAY_TIME=12:00
TIME_MASTER_AFTERNOON_TIME=14:00
TIME_MASTER_DAY_CLOSE_TIME=18:00
TIME_MASTER_EVENING_START=20:00
TIME_MASTER_EVENING_END=22:00
TIME_MASTER_NO_RESPONSE_MINUTES=15
CODEX_BIN=/Applications/ChatGPT.app/Contents/Resources/codex
CODEX_MODEL=gpt-5.3-codex-spark
CODEX_REASONING_EFFORT=low
CODEX_TIMEOUT_MS=45000

# Local HTTP service.
PORT=8787

# Feishu custom bot webhook for sending messages back to the group.
# Keep real secrets in .env only.
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Feishu OpenAPI app credentials for creating official Feishu Tasks.
# Required for "create task list / task items" behavior.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TASKLIST_GUID=
FEISHU_TASK_ASSIGNEE_ID=
FEISHU_TASKLIST_MEMBER_ID=
FEISHU_TASKLIST_MEMBER_ID_TYPE=open_id

# Feishu event verification token / encrypt key, if using event subscription.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_P2P_CHAT_ID=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
