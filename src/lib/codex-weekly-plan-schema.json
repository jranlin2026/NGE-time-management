{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcomes", "deliverableChanges", "tasks"],
  "properties": {
    "outcomes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "deliverableChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "projectId", "milestoneId", "deliverableId", "name", "weight", "status"],
        "properties": {
          "action": { "type": "string", "enum": ["add", "update", "remove"] },
          "projectId": { "type": "string", "minLength": 1 },
          "milestoneId": { "type": "string", "minLength": 1 },
          "deliverableId": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 100 },
          "status": { "type": "string", "enum": ["pending", "doing", "accepted", "blocked"] }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "projectId", "projectName", "milestoneId", "deliverableId", "title", "deliverable", "completionStandard", "minutes", "date", "requiresEvidence", "impact"],
        "properties": {
          "taskId": { "type": "string", "minLength": 1 },
          "projectId": { "type": "string", "minLength": 1 },
          "projectName": { "type": "string", "minLength": 1 },
          "milestoneId": { "type": "string", "minLength": 1 },
          "deliverableId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "deliverable": { "type": "string", "minLength": 1 },
          "completionStandard": { "type": "string", "minLength": 1 },
          "minutes": { "type": "integer", "minimum": 5, "maximum": 480 },
          "date": { "type": "string", "minLength": 1 },
          "requiresEvidence": { "type": "boolean" },
          "impact": { "type": "string", "enum": ["normal", "system_unusable_bug"] }
        }
      }
    }
  }
}
