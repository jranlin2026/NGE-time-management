{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["items", "combinedReplyContext"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["messageIds", "category", "disposition", "title", "projectId", "urgency", "mustBeOwner", "estimateMinutes", "dueAt", "nextAction", "doneDefinition", "checkpoints", "rationale"],
        "properties": {
          "messageIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "category": { "type": "string", "enum": ["task", "idea", "system_bug", "meeting", "blocker", "defer_reason", "evidence", "communication"] },
          "disposition": { "type": "string", "enum": ["interrupt_now", "schedule_today", "candidate_pool", "do_not_schedule", "task_feedback", "evidence_submission", "no_action"] },
          "title": { "type": "string", "minLength": 1 },
          "projectId": { "type": ["string", "null"], "minLength": 1 },
          "urgency": { "type": "string", "enum": ["high", "medium", "low"] },
          "mustBeOwner": { "type": "boolean" },
          "estimateMinutes": { "type": "integer", "minimum": 1 },
          "dueAt": { "type": ["string", "null"] },
          "nextAction": { "type": "string", "minLength": 1 },
          "doneDefinition": { "type": "string", "minLength": 1 },
          "checkpoints": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "minutes"],
              "properties": {
                "title": { "type": "string", "minLength": 1 },
                "minutes": { "type": "integer", "minimum": 15, "maximum": 45 }
              }
            }
          },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "combinedReplyContext": { "type": "string" }
  }
}
